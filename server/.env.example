# ===== 搴旂敤閰嶇疆 =====
NODE_ENV=development
PORT=10310

# ===== 鏁版嵁搴?=====
DATABASE_URL="mysql://root:password@localhost:3306/infrared_cloud"

# ===== JWT =====
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== 瀵嗙爜鍝堝笇 =====
BCRYPT_SALT_ROUNDS=10

# ===== Turnstile (Cloudflare) =====
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY_REGISTER=1x0000000000000000000000000000000AA
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# ===== 璁惧閰嶇疆 =====
DEVICE_TOKEN_LENGTH=32
HEARTBEAT_TIMEOUT_SECONDS=300

# ===== 鏁版嵁淇濈暀 =====
DATA_RETENTION_DAYS=90

# ===== 瓒呯骇绠＄悊鍛?(seed 鑴氭湰浣跨敤) =====
SEED_ADMIN_EMAIL=admin@infrared-cloud.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# ===== OneBot (鍒濆閰嶇疆锛屼篃鍙湪绠＄悊鍚庡彴淇敼) =====
ONEBOT_WS_URL=ws://127.0.0.1:8080
ONEBOT_TOKEN=

# ===== 閫熺巼闄愬埗 =====
RATE_LIMIT_AUTH=5
RATE_LIMIT_REPORT=60
